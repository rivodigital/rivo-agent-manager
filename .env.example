# ============================================================================
# Rivo Agent Manager — Production Environment Template
# ============================================================================
# Copie este arquivo para `.env` no servidor e preencha os valores.
# NUNCA commite o .env real no git.
# ============================================================================

# --- Domínio (usado pelo Caddy pra HTTPS automático) ---
DOMAIN=agentes.seudominio.com.br
ACME_EMAIL=seu-email@dominio.com.br

# --- Backend ---
# Token que o frontend usa pra autenticar nas rotas /api
# Gere um valor forte: openssl rand -hex 32
AUTH_TOKEN=troque-este-token-por-um-valor-forte

# Mensagem de fallback quando o LLM falha
FALLBACK_MESSAGE="Desculpe, estou com dificuldades técnicas no momento. Tente novamente em instantes."

# Buffer de mensagens (segundos pra agregar mensagens rápidas do mesmo lead)
MESSAGE_BUFFER_SECONDS=3

# Histórico passado pro LLM
CONVERSATION_HISTORY_LIMIT=20

# --- Evolution API ---
# Gere um valor forte: openssl rand -hex 32
EVOLUTION_API_KEY=troque-esta-key-por-um-valor-forte

# --- Webhook (URL interna que Evolution chama no backend) ---
# Como tudo roda na mesma rede Docker, use o nome do serviço
WEBHOOK_GLOBAL_URL=http://backend:3001/api/webhook/evolution

# --- Postgres da Evolution (interno, não exposto) ---
POSTGRES_EVOLUTION_USER=evolution
POSTGRES_EVOLUTION_PASSWORD=troque-esta-senha
POSTGRES_EVOLUTION_DB=evolution
